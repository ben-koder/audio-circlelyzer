# ── Rust build artifacts ─────────────────────────────────────────────────────
audio-circlelyzer-lib/target/
audio-circlelyzer-wasm/target/

# wasm-pack output dir (intermediate; copies go to app/public/ which IS tracked)
audio-circlelyzer-wasm/pkg/

# ── Node / Angular ────────────────────────────────────────────────────────────
audio-circlelyzer-app/node_modules/
audio-circlelyzer-app/dist/
audio-circlelyzer-app/.angular/
audio-circlelyzer-worklet/node_modules/
audio-circlelyzer-worklet/dist/

# WASM type declarations – internal copy in src/assets/wasm/ is regenerated by
# `npm run build:wasm` and is not needed in the repo (public/ copy IS committed)
audio-circlelyzer-app/src/assets/wasm/

# Angular-generated lock/cache files
npm-debug.log*
yarn-error.log*
.sass-cache/
/connect.lock
/coverage

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
testdata/dist/

# ── OS / editor artefacts ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
*.swp
*.swo
*~

# ── VS Code (keep project settings; ignore per-user private state) ────────────
# (The app sub-project's .gitignore already handles .vscode for its subtree;
#  this rule covers the root .vscode/ folder.)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
